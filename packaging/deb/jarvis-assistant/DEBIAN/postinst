#!/bin/bash
set -e

INSTALL_DIR="/usr/share/jarvis-assistant"

# Detectar usuário real (não root)
if [ -n "$SUDO_USER" ]; then
    REAL_USER="$SUDO_USER"
    REAL_HOME=$(getent passwd "$SUDO_USER" | cut -d: -f6)
else
    REAL_USER="$USER"
    REAL_HOME="$HOME"
fi

# Usar o python3 do sistema (não pip3 do usuário, que pode ser de outra versão)
SYS_PYTHON=$(command -v python3 || command -v python3.8 || command -v python3.9 || command -v python3.10)

# Atualizar pip do sistema antes — pip antigo (Ubuntu 20.04 tem pip 20) não instala PyQt6
"$SYS_PYTHON" -m pip install --upgrade pip --quiet 2>/dev/null || true

# Instalar dependências Python para o python3 do sistema
"$SYS_PYTHON" -m pip install --quiet \
    PyQt6 psutil distro gTTS "edge-tts>=6.1.9" SpeechRecognition 2>/dev/null || true

# PyAudio via apt (mais confiável que pip para Ubuntu)
apt-get install -y python3-pyaudio -qq 2>/dev/null || true

# Criar config do usuário se não existir
USER_CONFIG="$REAL_HOME/.config/jarvis-assistant/jarvis.json"
if [ ! -f "$USER_CONFIG" ]; then
    mkdir -p "$(dirname "$USER_CONFIG")"
    cp "$INSTALL_DIR/config/jarvis.json" "$USER_CONFIG"
    # Ajustar dono do arquivo
    if [ -n "$SUDO_USER" ]; then
        chown "$SUDO_USER:$(id -gn "$SUDO_USER")" "$USER_CONFIG"
        chown "$SUDO_USER:$(id -gn "$SUDO_USER")" "$(dirname "$USER_CONFIG")"
    fi
fi


# Instalar ícones no tema freedesktop
for size in 16 24 32 48 64 128 256; do
    ICON_SRC="$INSTALL_DIR/assets/icons/jarvis_${size}.png"
    ICON_DST="/usr/share/icons/hicolor/${size}x${size}/apps"
    if [ -f "$ICON_SRC" ]; then
        mkdir -p "$ICON_DST"
        cp "$ICON_SRC" "$ICON_DST/jarvis-assistant.png"
    fi
done
gtk-update-icon-cache /usr/share/icons/hicolor 2>/dev/null || true

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║   J.A.R.V.I.S instalado com sucesso!        ║"
echo "╚══════════════════════════════════════════════╝"
echo ""
echo "  Executar:   jarvis-assistant"
echo "  Config:     $USER_CONFIG"
echo ""
