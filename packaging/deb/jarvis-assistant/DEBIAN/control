Package: jarvis-assistant
Version: 3.0.0
Section: utils
Priority: optional
Architecture: all
Depends: python3 (>= 3.10), python3-pip, python3-pyqt6, espeak-ng, mpg123
Recommends: python3-psutil, python3-distro
Maintainer: Otávio Melo <otavio.melo@meisters.solutions>
